#!/bin/sh
# Resolves bare `clay` to the platform binary for the pinned CLI version (see the
# cli-version file next to this script), downloading + checksum-verifying it from
# the matching clay-cli-v<version> GitHub release on first use and caching it.
set -eu

REPO="clay-run/agent-plugins"

# Bootstrap failures must honor the CLI's output contract (apps/cli/AGENTS.md):
# a JSON error envelope on stderr and a categorical exit code, so an agent that
# branches on the first `clay` invocation sees the same shape the binary emits.
die() {
  printf '{"error":{"code":"%s","message":"%s"}}\n' "$1" "$2" >&2
  exit "$3"
}

# Resolve our own path even when invoked as a bare command via PATH.
self="$0"
case "$self" in
  */*) ;;
  *) self="$(command -v -- "$self")" || die "internal_error" "clay: could not resolve its own path" 1 ;;
esac
bin_dir="$(cd -- "$(dirname -- "$self")" && pwd)"

# The plugin pins which CLI version it bundles via this file; the matching binaries
# live on the clay-cli-v<version> GitHub release (produced by the CLI release, not
# the plugin release), so the plugin and the CLI version are decoupled.
version_file="$bin_dir/cli-version"
if [ ! -f "$version_file" ]; then
  die "internal_error" "clay: missing $version_file (reinstall the plugin from $REPO)" 1
fi
version="$(tr -d '[:space:]' < "$version_file")"
if [ -z "$version" ]; then
  die "internal_error" "clay: empty CLI version in $version_file" 1
fi

os="$(uname -s)"
arch="$(uname -m)"
case "$os" in
  Darwin) os="darwin" ;;
  Linux) os="linux" ;;
  *) die "validation_error" "clay: unsupported OS: $os" 2 ;;
esac
case "$arch" in
  arm64 | aarch64) arch="arm64" ;;
  x86_64 | amd64) arch="x64" ;;
  *) die "validation_error" "clay: unsupported architecture: $arch" 2 ;;
esac
# The bundled binaries are glibc-linked. Detect the active libc by the glibc
# dynamic loader the binary actually needs, not by guessing from libc files on disk
# (a glibc host may also have musl installed). If that loader is absent (e.g.
# Alpine/musl), fail with a categorical error instead of a cryptic loader crash.
if [ "$os" = linux ]; then
  case "$arch" in
    arm64) glibc_loader="/lib/ld-linux-aarch64.so.1" ;;
    x64) glibc_loader="/lib64/ld-linux-x86-64.so.2" ;;
    *) glibc_loader="" ;;
  esac
  if [ -n "$glibc_loader" ] && [ ! -e "$glibc_loader" ]; then
    die "validation_error" "clay: missing the glibc dynamic loader ($glibc_loader); the Clay CLI requires glibc (Alpine/musl is not supported)" 2
  fi
fi
platform="$os-$arch"
asset="clay-$platform"

if [ -n "${CLAY_CONFIG_HOME:-}" ]; then
  config_base="$CLAY_CONFIG_HOME"
elif [ -n "${XDG_CONFIG_HOME:-}" ]; then
  config_base="$XDG_CONFIG_HOME"
elif [ -n "${HOME:-}" ]; then
  config_base="$HOME/.config"
else
  die "internal_error" "clay: cannot resolve a config dir (set CLAY_CONFIG_HOME, XDG_CONFIG_HOME, or HOME)" 1
fi
cache_dir="$config_base/clay/bin"
cached="$cache_dir/clay-$version-$platform"

if [ ! -x "$cached" ] || [ ! -s "$cached" ]; then
  checksums="$bin_dir/checksums.txt"
  if [ ! -f "$checksums" ]; then
    die "internal_error" "clay: missing $checksums (reinstall the plugin from $REPO)" 1
  fi
  expected="$(awk -v a="$asset" '$2 == a {print $1}' "$checksums" | head -n1)"
  if [ -z "$expected" ]; then
    die "internal_error" "clay: no checksum for $asset (clay-cli-v$version) in $checksums" 1
  fi

  url="https://github.com/$REPO/releases/download/clay-cli-v$version/$asset"
  # Progress output is non-JSON, so keep it off the contract path unless asked.
  if [ -n "${CLAY_DEBUG:-}" ]; then
    echo "clay: installing CLI $version ($platform)..." >&2
  fi
  mkdir -p "$cache_dir"
  tmp="$cache_dir/.dl-$$"
  trap 'rm -f "$tmp"' EXIT INT TERM
  if command -v curl > /dev/null 2>&1; then
    curl -fsSL "$url" -o "$tmp" || die "network_error" "clay: failed to download the CLI from $url" 5
  elif command -v wget > /dev/null 2>&1; then
    wget -qO "$tmp" "$url" || die "network_error" "clay: failed to download the CLI from $url" 5
  else
    die "internal_error" "clay: need curl or wget to download the CLI" 1
  fi

  if command -v sha256sum > /dev/null 2>&1; then
    actual="$(sha256sum "$tmp" | awk '{print $1}')"
  elif command -v shasum > /dev/null 2>&1; then
    actual="$(shasum -a 256 "$tmp" | awk '{print $1}')"
  else
    die "internal_error" "clay: need sha256sum or shasum to verify the download" 1
  fi
  if [ "$actual" != "$expected" ]; then
    die "internal_error" "clay: checksum mismatch for $asset (expected $expected, got $actual)" 1
  fi

  chmod +x "$tmp" || die "internal_error" "clay: failed to make the downloaded CLI executable" 1
  mv -f "$tmp" "$cached" || die "internal_error" "clay: failed to install the CLI to $cached" 1
  trap - EXIT INT TERM
fi

exec "$cached" "$@"
